# ── Backend ──────────────────────────────────────────────────────────────────

# Port the Go server listens on (Cloud Run sets this automatically)
PORT=8080

# Path to the inspection module JSON files
ARGUS_MODULES_DIR=./modules

# Google Gemini API key — get one at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Demo access codes — comma-separated, users enter one of these to access /session
# Leave empty to disable the gate (open access)
DEMO_TOKENS=ARGUS-DEMO1,ARGUS-SITE2,ARGUS-ELEV3

# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# WebSocket backend URL — must start with ws:// or wss://
# Local dev:  ws://localhost:8080/ws
# Production: wss://your-cloud-run-url/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
